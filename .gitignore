# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
dodd_analytical_model/

# Training data
*.npy
*.csv
data/training/archive_*/
data/raw/
training_data/
training_data_archive_*/

# Model results and checkpoints
models/*/results/
models/*/checkpoints/
*.ckpt
*.pkl

# Results: ignore epoch checkpoints but keep final models
results/**/models/netG_epoch_*.pth
results/**/models/netC_epoch_*.pth
results/**/models/netG_epoch_*.pt
results/**/models/netC_epoch_*.pt
!results/**/models/*_final.pth
!results/**/models/*_final.pt

# Results: ignore training images, report images, and generated .npy
results/**/training_images/
results/**/report_*/*.png
results/**/report_*/generated_*.npy
results/**/quality_report/plots/
results/**/training_curves.png
results/**/*.png

# Training outputs
results/experiments/*
results/visualizations/*
results/quality_reports/*
*.log

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Runpod
runpod/.env
models/runpod/.env

# Legacy (keep in git for reference, but ignore generated outputs)
models/legacy/results/
models/legacy/img/
models/legacy/nets/

# Temporary files
*.tmp
*.bak
*.swp

# Large files
*.zip
*.tar.gz
*.rar
*.gif

# Don't ignore normalization params (needed for reproducibility)
!data/training/normalization_params.json
!**/normalization_params.json
