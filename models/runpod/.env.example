# RunPod SSH Connection
RUNPOD_SSH_HOST=<your-pod-host>
RUNPOD_SSH_PORT=<your-pod-port>
RUNPOD_SSH_USER=root
RUNPOD_SSH_KEY=~/.ssh/id_ed25519

# RunPod API (optional, for runpodctl CLI)
RUNPOD_API_KEY=<your-runpod-api-key>

# Project paths
REMOTE_PROJECT_DIR=/workspace/GANs-for-1D-Signal
LOCAL_PROJECT_DIR=.
